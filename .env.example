# ============================================================
# Canal Engine — variáveis de ambiente (exemplo)
# Copie para .env.local e preencha quando for ativar cada integração.
# NENHUMA chave é necessária para rodar o sistema agora (tudo é local/heurístico).
# ============================================================

# --- Turso / libSQL (banco durável em produção) — RECOMENDADO p/ Vercel ---
# BANCO OFICIAL: "canal-engine"  (use SOMENTE este; NÃO misture com canal-enginevitor)
#
# REGRA DE OURO: a URL e o token DEVEM ser do MESMO banco. URL de um banco com
# token de outro = erro "Unauthorized at new Database". Sem as duas variáveis, o
# app cai em modo demo local (não quebra).
#
# Passo a passo:
#   turso db create canal-engine                 # (uma vez)
#   turso db show canal-engine --url             # → TURSO_DATABASE_URL
#   turso db tokens create canal-engine          # → TURSO_AUTH_TOKEN (JWT eyJ...)
#   npm run turso:migrate                        # popula os 5 canais no Turso
#
# TURSO_DATABASE_URL=libsql://canal-engine-SEU-USUARIO.turso.io
# TURSO_AUTH_TOKEN=eyJ...

# --- YouTube (dados reais de tendências e métricas) — FUTURO ---
# YOUTUBE_API_KEY=
# YOUTUBE_OAUTH_CLIENT_ID=
# YOUTUBE_OAUTH_CLIENT_SECRET=
# YOUTUBE_ANALYTICS_ENABLED=false

# --- Modelos de texto (ideias/roteiros/SEO) — FUTURO ---
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# AI_TEXT_PROVIDER=local        # local | openai | gemini

# --- Geração de vídeo/imagem (thumbnails, b-roll) — FUTURO ---
# VEO_API_KEY=
# RUNWAY_API_KEY=
# KLING_API_KEY=
# MEDIA_PROVIDER=local          # local | veo | runway | kling

# Enquanto as chaves acima estiverem vazias, o sistema usa as skills locais
# (heurísticas determinísticas) — sem custo e sem dependência externa.
